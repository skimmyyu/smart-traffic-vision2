<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.traffic.mapper.WhitelistMapper">

    <resultMap id="WhitelistMap" type="com.traffic.entity.Whitelist">
        <id property="id" column="id"/>
        <result property="plateNumber" column="plate_number"/>
    </resultMap>

    <select id="findAll" resultMap="WhitelistMap">
        SELECT id, plate_number
        FROM whitelist
        ORDER BY id
    </select>

    <select id="findByPlateNumber" resultMap="WhitelistMap">
        SELECT id, plate_number
        FROM whitelist
        WHERE plate_number = #{plateNumber}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO whitelist (plate_number)
        VALUES (#{plateNumber})
    </insert>

    <delete id="deleteByPlateNumber">
        DELETE FROM whitelist
        WHERE plate_number = #{plateNumber}
    </delete>

</mapper>
